{
  "name": "pokemon-page-test",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build && node -e \"fs.copyFileSync('dist/index.html','dist/404.html')\"",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/vue-query": "^5.100.9",
    "@tanstack/vue-query-devtools": "^6.1.28",
    "@vueuse/core": "^14.3.0",
    "canvas-confetti": "^1.9.4",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.4",
    "vue": "^3.5.32",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^4.1.5",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  }
}
